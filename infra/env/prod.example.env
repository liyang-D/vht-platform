APP_ENV=prod

POSTGRES_DB=vht_prod
POSTGRES_USER=vht_prod
POSTGRES_PASSWORD=change-me-prod
DATABASE_URL=postgresql://vht_prod:change-me-prod@postgres:5432/vht_prod

HF_TOKEN=
NGC_API_KEY=
LLM_PROVIDER=openai-compatible
LLM_API_BASE_URL=http://llm:8000/v1
LLM_API_KEY=EMPTY
LLM_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507
ORCHESTRATOR_LLM_MAX_CONCURRENT_REQUESTS=4
ORCHESTRATOR_ASR_MAX_CONCURRENT_REQUESTS=1
ORCHESTRATOR_TTS_MAX_CONCURRENT_REQUESTS=1
RUNTIME_REQUEST_MAX_RETRIES=2
RUNTIME_REQUEST_RETRY_BACKOFF_SECONDS=0.5
LLM_GPU_MEMORY_UTILIZATION=0.65
LLM_MAX_MODEL_LEN=16384
ASR_PROVIDER=riva
ASR_MODEL=parakeet-1-1b-ctc-en-us
ASR_DEFAULT_DOMAIN=default
ASR_DEFAULT_MODE=offline
ASR_DOMAIN_CONFIG_PATH=/app/services/orchestrator/config/asr_domains.json
ASR_NIM_CONTAINER_ID=parakeet-1-1b-ctc-en-us
ASR_NIM_TAG=latest
ASR_NIM_TAGS_SELECTOR=name=parakeet-1-1b-ctc-en-us,mode=all
RIVA_ASR_HTTP_URL=http://asr:9000
RIVA_ASR_LANGUAGE=en-US
RIVA_ASR_ENABLE_AUTOMATIC_PUNCTUATION=true
RIVA_ASR_BOOSTED_WORDS_FIELD=boosted_words
RIVA_ASR_BOOST_SCORE_FIELD=boost_score
TTS_PROVIDER=chatterbox
TTS_MODEL=chatterbox-turbo
CHATTERBOX_TTS_MODEL=chatterbox-turbo
CHATTERBOX_TTS_DEVICE=cuda
CHATTERBOX_TTS_VOICE=default
CHATTERBOX_TTS_AUDIO_PROMPT_PATH=/voices/default.wav
CHATTERBOX_TTS_HTTP_URL=http://tts:8000
TTS_NIM_CONTAINER_ID=magpie-tts-multilingual
TTS_NIM_TAG=latest
TTS_NIM_TAGS_SELECTOR=name=magpie-tts-multilingual,batch_size=8
RIVA_TTS_HTTP_URL=http://tts-riva:9000
RIVA_TTS_LANGUAGE=en-US
RIVA_TTS_VOICE=Magpie-Multilingual.EN-US.Aria
DEEPGRAM_API_KEY=
DEEPGRAM_ASR_MODEL=nova-3
DEEPGRAM_TTS_MODEL=aura-2-thalia-en

SIMPLE_CHAT_ACCESS_KEY=change-me-prod-access-key
DEFAULT_PROJECT_NAME=Mini Project Template
SIMPLE_CHAT_COOKIE_SECURE=true
SIMPLE_CHAT_CORS_ALLOW_ORIGINS=
SIMPLE_CHAT_ORCHESTRATOR_TIMEOUT_SECONDS=300
BACKEND_PROXY_TIMEOUT=300s
SIMPLE_CHAT_FRONTEND_PORT=8080
